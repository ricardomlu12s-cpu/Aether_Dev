AETHER_ADMIN_TOKEN=change-me
AETHER_L1_MESSAGE_LIMIT=12
# mock | openai | openai_compatible
AETHER_MODEL_PROVIDER=mock
AETHER_MODEL_NAME=gpt-4.1-mini
AETHER_MODEL_BASE_URL=https://api.openai.com/v1
# AETHER_MODEL_API_KEY=
# local | chroma | lancedb
AETHER_VECTOR_BACKEND=local
AETHER_CHROMA_COLLECTION=aether_memories
AETHER_LANCEDB_TABLE=aether_memories
# Optional for development/tests. Packaged macOS app should use ~/Library/Application Support/Aether Dev by default.
# AETHER_DATA_DIR=/absolute/path/to/Aether Dev data
# Defaults to ~/Library/Application Support/Aether Dev/aether.sqlite3
# AETHER_DATABASE_PATH=/absolute/path/aether.sqlite3
